  const LABELS: Record<string, string> = {
    react: 'React',
    vanilla: 'Vanilla',
    vue: 'Vue',
    svelte: 'Svelte',
  };

  const root = document.documentElement;
  const select = document.getElementById('fw-select') as HTMLDetailsElement;
  const currentIcon = select.querySelector('[data-current-icon]')!;
  const currentLabel = select.querySelector('[data-current-label]')!;

  for (const el of select.querySelectorAll<HTMLElement>('.fw-icon[data-icon]')) {
    el.innerHTML = ICONS[el.dataset.icon!]!;
  }

  function apply(fw: string) {
    root.dataset.fw = fw;
    currentIcon.innerHTML = ICONS[fw]!;
    currentLabel.textContent = LABELS[fw]!;
    try {
      localStorage.setItem('crd-ui-fw', fw);
    } catch {}
  }

  apply(root.dataset.fw && root.dataset.fw in LABELS ? root.dataset.fw : 'react');

  for (const btn of select.querySelectorAll<HTMLButtonElement>('.fw-option[data-fw]')) {
    btn.addEventListener('click', () => {
      apply(btn.dataset.fw!);
      select.open = false;
    });
  }

  document.addEventListener('click', (e) => {
    if (select.open && !select.contains(e.target as Node)) select.open = false;
  });
</script>
