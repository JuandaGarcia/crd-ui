---
// Inline framework picker for the masthead ("crd-ui for React ▾").
// React is the default; Vue/Svelte are visible but disabled until they ship.
---

<details class="fw-select" id="fw-select">
  <summary aria-label="Choose framework">
    <span class="fw-icon" data-current-icon></span>
    <span data-current-label>React</span>
    <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>
  <div class="fw-menu" role="menu">
    <button class="fw-option" data-fw="react" type="button">
      <span class="fw-icon" data-icon="react"></span>React
      <svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M20 6 9 17l-5-5"></path>
      </svg>
    </button>
    <button class="fw-option" data-fw="vanilla" type="button">
      <span class="fw-icon" data-icon="vanilla"></span>Vanilla
      <svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M20 6 9 17l-5-5"></path>
      </svg>
    </button>
    <button class="fw-option" type="button" disabled>
      <span class="fw-icon" data-icon="vue"></span>Vue<span class="fw-soon">soon</span>
    </button>
    <button class="fw-option" type="button" disabled>
      <span class="fw-icon" data-icon="svelte"></span>Svelte<span class="fw-soon">soon</span>
    </button>
  </div>
</details>

<script>
  const ICONS: Record<string, string> = {
    react:
      '<svg viewBox="0 0 24 24" fill="none" stroke="#58c4dc" stroke-width="1"><circle cx="12" cy="12" r="2" fill="#58c4dc" stroke="none"/><ellipse cx="12" cy="12" rx="10" ry="4.2"/><ellipse cx="12" cy="12" rx="10" ry="4.2" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4.2" transform="rotate(120 12 12)"/></svg>',
    vanilla:
      '<svg viewBox="0 0 24 24"><rect width="24" height="24" rx="3" fill="#f7df1e"/><text x="12" y="17" text-anchor="middle" font-family="sans-serif" font-size="11" font-weight="700" fill="#000">JS</text></svg>',
    vue: '<svg viewBox="0 0 24 24"><path d="M2 4h4.4L12 13.5 17.6 4H22L12 21z" fill="#41b883"/><path d="M6.4 4h3.2L12 8.2 14.4 4h3.2L12 13.5z" fill="#35495e"/></svg>',
    svelte:
      '<svg viewBox="0 0 24 24"><rect width="24" height="24" rx="5" fill="#ff3e00"/><text x="12" y="17" text-anchor="middle" font-family="sans-serif" font-size="12" font-weight="700" fill="#fff">S</text></svg>',
  };
  const LABELS: Record<string, string> = { react: 'React', vanilla: 'Vanilla' };

  const root = document.documentElement;
  const select = document.getElementById('fw-select') as HTMLDetailsElement;
  const currentIcon = select.querySelector('[data-current-icon]')!;
  const currentLabel = select.querySelector('[data-current-label]')!;

  for (const el of select.querySelectorAll<HTMLElement>('.fw-icon[data-icon]')) {
    el.innerHTML = ICONS[el.dataset.icon!]!;
  }

  function apply(fw: string) {
    root.dataset.fw = fw;
    currentIcon.innerHTML = ICONS[fw]!;
    currentLabel.textContent = LABELS[fw]!;
    try {
      localStorage.setItem('crd-ui-fw', fw);
    } catch {}
  }

  apply(root.dataset.fw === 'vanilla' ? 'vanilla' : 'react');

  for (const btn of select.querySelectorAll<HTMLButtonElement>('.fw-option[data-fw]')) {
    btn.addEventListener('click', () => {
      apply(btn.dataset.fw!);
      select.open = false;
    });
  }

  document.addEventListener('click', (e) => {
    if (select.open && !select.contains(e.target as Node)) select.open = false;
  });
</script>
