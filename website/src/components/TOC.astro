---
// Left-gutter table of contents with scrollspy, after NumberFlow's TOC:
// section tops are cached on resize; on scroll, the last heading above the
// scroll position (accounting for scroll-padding-top) becomes active.
const items = [
  { id: 'playground', title: 'Try it' },
  { id: 'usage', title: 'Usage' },
  { id: 'brands', title: 'Brands' },
  { id: 'theming', title: 'Theming' },
  { id: 'localization', title: 'Localization' },
  { id: 'api', title: 'API' },
];
---

<nav class="toc" id="toc" aria-label="On this page">
  <ol>
    {items.map((item) => (
      <li><a href={`#${item.id}`}>{item.title}</a></li>
    ))}
  </ol>
</nav>

<script>
  const links = [...document.querySelectorAll<HTMLAnchorElement>('#toc a')];
  const sections = links.map((a) => document.getElementById(a.getAttribute('href')!.slice(1)));
  let scrollPt = 0;

  function measureScrollPt() {
    const raw = getComputedStyle(document.documentElement)
      .getPropertyValue('scroll-padding-top')
      .match(/[\d.]+/)?.[0];
    scrollPt = raw ? parseFloat(raw) : 0;
  }

  // Positions are read live on every scroll (island hydration shifts section
  // offsets), and the threshold is a reading line ~20% down the viewport so
  // anchor landings that end up a few px off still activate their section.
  function update() {
    const threshold = scrollPt + window.innerHeight * 0.2;
    let active = 0;
    sections.forEach((el, i) => {
      if (el && el.getBoundingClientRect().top <= threshold) active = i;
    });
    links.forEach((a, i) => {
      if (i === active) a.setAttribute('data-active', '');
      else a.removeAttribute('data-active');
    });
  }

  window.addEventListener('resize', measureScrollPt);
  window.addEventListener('scroll', update, { passive: true });
  measureScrollPt();
  update();
</script>
