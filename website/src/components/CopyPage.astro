---
// shadcn-style "Copy Page" split button: the main action copies the page's
// markdown twin; the menu links the markdown view and AI assistants.
// Brand marks (OpenAI, Claude, Markdown) from simple-icons, monochrome.
//
// The border-beam runs on a dedicated overlay layer covering only the button
// bar — its wrapper clips with overflow:hidden, so nesting the dropdown inside
// it would clip the menu away.
import { BorderBeam } from 'border-beam';

// Same prompt wording shadcn/ui uses for its "Open in ..." menu.
const MD_URL = 'https://crd-ui.juanda.co/llms-full.txt';
const PROMPT =
  `I’m looking at this crd-ui documentation: ${MD_URL}.\n` +
  'Help me understand how to use it. Be ready to explain concepts, give examples, or help debug based on it.';
const Q = encodeURIComponent(PROMPT);
const V0_URL = `https://v0.dev/?q=${Q}`;
const CHATGPT_URL = `https://chatgpt.com/?hints=search&q=${Q}`;
const CLAUDE_URL = `https://claude.ai/new?q=${Q}`;
const SCIRA_URL = `https://scira.ai/?q=${Q}`;
---

<div class="copy-page">
  <div class="copy-page__beam" aria-hidden="true">
    <BorderBeam client:load size="sm" colorVariant="sunset" theme="auto" borderRadius={10}>
      <div class="copy-page__beam-fill"></div>
    </BorderBeam>
  </div>
  <button class="copy-page__main" id="copy-page-btn" type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="9" y="9" width="12" height="12" rx="2"></rect>
      <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
    </svg>
    <span class="copy-page__label">Copy Page</span>
  </button>
  <details class="copy-page__more" id="copy-page-menu">
    <summary aria-label="Page options">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </summary>
    <div class="copy-menu" role="menu">
      <a class="copy-option" href="/index.md" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.27 19.385H1.73A1.73 1.73 0 010 17.655V6.345a1.73 1.73 0 011.73-1.73h20.54A1.73 1.73 0 0124 6.345v11.308a1.73 1.73 0 01-1.73 1.731zM5.769 15.923v-4.5l2.308 2.885 2.307-2.885v4.5h2.308V8.078h-2.308l-2.307 2.885-2.308-2.885H3.46v7.847zM21.232 12h-2.309V8.077h-2.307V12h-2.308l3.461 4.039z"></path>
        </svg>
        View as Markdown
      </a>
      <a class="copy-option" href={V0_URL} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M14.066 6.028v2.22h5.729q.075-.001.148.005l-5.853 5.752a2 2 0 0 1-.024-.309V8.247h-2.353v5.45c0 2.322 1.935 4.222 4.258 4.222h5.675v-2.22h-5.675q-.03 0-.059-.003l5.729-5.629q.006.082.006.166v5.465H24v-5.465a4.204 4.204 0 0 0-4.205-4.205zM0 8.245l8.28 9.266c.839.94 2.396.346 2.396-.914V8.245H8.19v5.44l-4.86-5.44Z"></path>
        </svg>
        Open in v0
      </a>
      <a class="copy-option" href={CHATGPT_URL} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"></path>
        </svg>
        Open in ChatGPT
      </a>
      <a class="copy-option" href={CLAUDE_URL} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z"></path>
        </svg>
        Open in Claude
      </a>
      <a class="copy-option" href={SCIRA_URL} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          <path d="M19 3v4"></path>
          <path d="M21 5h-4"></path>
        </svg>
        Open in Scira
      </a>
    </div>
  </details>
</div>

<style>
  .copy-page {
    position: absolute;
    top: clamp(1.25rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    z-index: 30;
    display: flex;
    align-items: stretch;
    border-radius: 0.625rem;
    box-shadow: 0 0 0 1px var(--ring);
    background: var(--hover-wash);
    font-size: 0.8125rem;
    font-weight: 500;
  }

  /* Beam overlay: hugs the button bar, never intercepts clicks. The island's
     internal wrappers are React-rendered (no Astro scope class), hence the
     :global sizing. */
  .copy-page__beam {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .copy-page__beam :global(astro-island),
  .copy-page__beam :global(astro-island > div) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .copy-page__beam-fill {
    width: 100%;
    height: 100%;
    border-radius: 0.625rem;
  }

  .copy-page__main {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.65rem;
    border: 0;
    border-radius: 0.625rem 0 0 0.625rem;
    background: none;
    color: var(--text);
    font: inherit;
    cursor: pointer;
    transition: background 0.16s ease-out;
  }

  .copy-page__main svg,
  .copy-page__more summary svg,
  .copy-option svg {
    width: 0.9375rem;
    height: 0.9375rem;
    flex-shrink: 0;
  }

  .copy-page__main:hover {
    background: var(--bg);
  }

  .copy-page__more {
    position: relative;
    display: flex;
    border-left: 1px solid var(--border-faint);
  }

  .copy-page__more summary {
    list-style: none;
    display: flex;
    align-items: center;
    padding: 0 0.45rem;
    border-radius: 0 0.625rem 0.625rem 0;
    color: var(--muted);
    cursor: pointer;
    transition:
      background 0.16s ease-out,
      color 0.16s ease-out;
  }

  .copy-page__more summary::-webkit-details-marker {
    display: none;
  }

  .copy-page__more summary:hover,
  .copy-page__more[open] summary {
    background: var(--bg);
    color: var(--text);
  }

  .copy-page__more summary svg {
    transition: transform 0.15s ease-out;
  }

  .copy-page__more[open] summary svg {
    transform: rotate(180deg);
  }

  .copy-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    min-width: 12rem;
    background: var(--popover-bg);
    border-radius: 0.75rem;
    padding: 0.375rem;
    box-shadow:
      0 0 0 1px var(--ring),
      0 1px 2px rgba(0, 0, 0, 0.05);
    display: grid;
    z-index: 20;
  }

  .copy-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }

  .copy-option:hover {
    background: var(--hover-wash);
  }

  .copy-option svg {
    color: var(--muted);
  }

  @media (max-width: 40rem) {
    .copy-page__label {
      display: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('copy-page-btn')!;
  const menu = document.getElementById('copy-page-menu') as HTMLDetailsElement;
  const label = btn.querySelector('.copy-page__label');

  btn.addEventListener('click', async () => {
    const md = await fetch('/llms-full.txt').then((r) => r.text());
    await navigator.clipboard.writeText(md);
    if (label) {
      const prev = label.textContent;
      label.textContent = 'Copied!';
      setTimeout(() => (label.textContent = prev), 1200);
    }
  });

  document.addEventListener('click', (e) => {
    if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
  });
</script>
