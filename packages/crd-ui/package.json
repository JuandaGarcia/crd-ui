{
  "name": "crd-ui",
  "version": "0.7.1",
  "description": "Framework-agnostic credit/debit card visualization. Zero-dependency vanilla core with React, Vue and Svelte subpaths.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/Card.svelte",
      "default": "./dist/svelte/Card.svelte"
    },
    "./styles.css": "./styles/crd-ui.css"
  },
  "files": [
    "dist",
    "styles",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/svelte && cp src/svelte/Card.svelte src/svelte/index.d.ts dist/svelte/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "credit-card",
    "debit-card",
    "card",
    "ui",
    "component",
    "vanilla",
    "react",
    "vue",
    "svelte"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuandaGarcia/crd-ui.git"
  },
  "homepage": "https://github.com/JuandaGarcia/crd-ui#readme",
  "bugs": "https://github.com/JuandaGarcia/crd-ui/issues",
  "peerDependencies": {
    "react": ">=18",
    "svelte": ">=5",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svelte": "^5.56.7",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "vue": "^3.5.40"
  }
}
