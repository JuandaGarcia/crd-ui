{
  "name": "crd-ui",
  "version": "0.1.0",
  "description": "Framework-agnostic credit/debit card visualization. Zero-dependency vanilla core with a React subpath (Vue and Svelte planned).",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["*.css"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./styles.css": "./styles/crd-ui.css"
  },
  "files": ["dist", "styles"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "credit-card",
    "debit-card",
    "card",
    "ui",
    "component",
    "vanilla",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuandaGarcia/crd-ui.git"
  },
  "homepage": "https://github.com/JuandaGarcia/crd-ui#readme",
  "bugs": "https://github.com/JuandaGarcia/crd-ui/issues",
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
