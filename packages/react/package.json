{
  "name": "@kardz/react",
  "version": "0.1.0",
  "description": "React component for kardz — credit/debit card visualization.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["credit-card", "debit-card", "card", "react", "component"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuandaGarcia/kardz.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/JuandaGarcia/kardz#readme",
  "bugs": "https://github.com/JuandaGarcia/kardz/issues",
  "dependencies": {
    "kardz": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
